{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  // https://docs.microsoft.com/en-us/cpp/build/launch-vs-schema-reference-cpp
  "version": "0.2.0",
  "configurations": [
    {
      "name": "gdb: Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/executable",
      "args": [],
      "stopAtEntry": false,
      "targetArchitecture": "amd64",
      "customLaunchSetupCommands": [
        { "description": "", "text": "file executable" },
        { "description": "", "text": "break syscall_wrapper.s:18" },
        { "description": "", "text": "break syscall_wrapper.s:19" }
      ],
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "as & ld: build workspace"
    }
  ]
}
