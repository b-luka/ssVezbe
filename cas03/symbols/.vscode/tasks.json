{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "gcc: build workspace",
      "command": "/usr/bin/gcc",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "-o",
        "${workspaceFolder}/executable",
        "${workspaceFolder}/symbol_usage.c",
        "${workspaceFolder}/symbol_definition.s"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "compiler: /usr/bin/gcc"
    }
  ]
}
